{
  "name": "vue-element-plus-admin",
  "version": "2.9.0",
  "description": "一套基于vue3、element-plus、typesScript、vite4的后台集成方案。",
  "author": "Archer <502431556@qq.com>",
  "private": false,
  "type": "module",
  "scripts": {
    "i": "pnpm install",
    "dev": "pnpm vite --mode base",
    "ts:check": "pnpm vue-tsc --noEmit --skipLibCheck",
    "build:pro": "pnpm vite build --mode pro",
    "build:gitee": "pnpm vite build --mode gitee",
    "build:dev": "pnpm vite build --mode dev",
    "build:test": "pnpm vite build --mode test",
    "serve:pro": "pnpm vite preview --mode pro",
    "serve:dev": "pnpm vite preview --mode dev",
    "serve:test": "pnpm vite preview --mode test",
    "npm:check": "pnpx npm-check-updates -u",
    "clean": "pnpx rimraf node_modules",
    "clean:cache": "pnpx rimraf node_modules/.cache",
    "lint:eslint": "eslint . --fix \"src/**/*.{js,ts,tsx,vue,html}\"",
    "lint:format": "prettier --write --loglevel warn \"src/**/*.{js,ts,json,tsx,css,less,vue,html,md}\"",
    "lint:style": "stylelint --fix \"**/*.{vue,less,postcss,css,scss}\" --cache --cache-location node_modules/.cache/stylelint/",
    "lint:lint-staged": "lint-staged -c ./.husky/lintstagedrc.cjs",
    "prepare": "husky install",
    "p": "plop",
    "icon": "esno ./scripts/icon.ts"
  },
  "dependencies": {
    "@iconify/iconify": "^3.1.1",
    "@iconify/vue": "^5.0.1",
    "@vueuse/core": "^14.3.0",
    "@wangeditor/editor": "^5.1.23",
    "@wangeditor/editor-for-vue": "^5.1.10",
    "@zxcvbn-ts/core": "^4.1.2",
    "animate.css": "^4.1.1",
    "axios": "^1.18.1",
    "cropperjs": "^1.6.2",
    "dayjs": "^1.11.21",
    "driver.js": "^1.6.0",
    "echarts": "^6.1.0",
    "echarts-wordcloud": "^2.1.0",
    "element-plus": "2.14.2",
    "lodash-es": "^4.18.1",
    "mitt": "^3.0.1",
    "monaco-editor": "^0.55.1",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "qrcode": "^1.5.4",
    "qs": "^6.15.3",
    "vue": "3.5.39",
    "vue-draggable-plus": "^0.6.1",
    "vue-i18n": "11.4.6",
    "vue-json-pretty": "^2.6.0",
    "vue-router": "^5.1.0",
    "vue-types": "^7.0.0",
    "xgplayer": "^3.0.24"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@iconify/json": "^2.2.497",
    "@intlify/unplugin-vue-i18n": "^11.2.4",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.10",
    "@types/lodash-es": "^4.17.12",
    "@types/mockjs": "^1.0.10",
    "@types/node": "^26.1.0",
    "@types/nprogress": "^0.2.3",
    "@types/qrcode": "^1.5.6",
    "@types/qs": "^6.15.1",
    "@types/sortablejs": "^1.15.9",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@unocss/transformer-variant-group": "^66.7.5",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.6",
    "autoprefixer": "^10.5.2",
    "chalk": "^5.6.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.2",
    "esno": "^4.8.0",
    "fs-extra": "^11.3.6",
    "husky": "^9.1.7",
    "inquirer": "^14.0.2",
    "knip": "^6.25.0",
    "less": "^4.6.7",
    "lint-staged": "^17.0.8",
    "mockjs": "^1.1.0",
    "plop": "^4.0.5",
    "postcss": "^8.5.16",
    "postcss-html": "^1.8.1",
    "postcss-less": "^6.0.0",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "rollup": "^4.62.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "stylelint": "^17.14.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "terser": "^5.48.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.63.0",
    "unocss": "^66.7.5",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "8.1.3",
    "vite-plugin-ejs": "^2.0.0",
    "vite-plugin-mock": "3.0.2",
    "vite-plugin-svg-icons": "^2.0.1",
    "vite-plugin-url-copy": "^1.1.4",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.6"
  },
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.1.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kailong321200875/vue-element-plus-admin.git"
